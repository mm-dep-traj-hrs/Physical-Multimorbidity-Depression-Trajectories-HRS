Mplus VERSION 8.8
MUTHEN & MUTHEN
04/10/2026  10:50 AM

INPUT INSTRUCTIONS

DATA: FILE = "mplus_file_df3.dat";
VARIABLE: 
NAMES = r11wtresp raestrat hhid pn hhidpn r11cesd r12cesd r13cesd r14cesd r15cesd
     r11agey_b r12agey_b r13agey_b r14agey_b r15agey_b r11iwstat r12iwstat r13iwstat
     r14iwstat r15iwstat r11hibp r11diab r11cancr r11lung r11heart r11strok r11arthr
     hbp12_c dia12_c can12_c lung12_c hrt12_c str12_c art12_c mcc_12 ragender female
     r11doctim r11doctim_q r11doctim_q1 r11doctim_q2 r11doctim_q3 r11doctim_q4 white
     black other latinx r12mstat mar_12 mar_f_12 educ_yr_f edu_c educ_c_1 educ_c_2
     educ_c_3 h11itot inc_q_12 inc_q1_12 inc_q2_12 inc_q3_12 inc_q4_12 h11atotb
     wlt_q_12 wlt_q1_12 wlt_q2_12 wlt_q3_12 wlt_q4_12 nonus_b bmi_12un bmi_12n
     bmi_12ow bmi_12ob vact_12c ch_circum ch_cir_0 ch_cir_1 ch_cir_2 ch_cir_3
     ch_cir_4 ch_cir_5 ch_hlth_p drnk_12 drnk_12_0 drnk_12_1 drnk_12_2 smoke_12
     combos no_cond_12 hbp_1_12 diab_1_12 can_1_12 lung_1_12 hrt_1_12 strk_1_12
     art_1_12 hbp_art hbp_hrt_art hbp_dia_art hbp_dia_hrt_art hbp_can_art hbp_dia
     hrt_art can_art hbp_lng_art oth_comb oth_sin_cond_12 combos_nm_reduc; 
MISSING=.;

  usevariables =
        r11cesd r12cesd r13cesd r14cesd r15cesd

        art_1_12 hbp_1_12 oth_sin_cond_12
        hbp_art hbp_hrt_art hbp_dia_art hbp_dia_hrt_art
        hbp_can_art hbp_dia hrt_art can_art hbp_lng_art
        oth_comb
        r11agey_b female mar_12 black other latinx nonus_b
        educ_c_1 educ_c_3
        inc_q2_12 inc_q3_12 inc_q4_12
        wlt_q2_12 wlt_q3_12 wlt_q4_12
        bmi_12un bmi_12ow bmi_12ob
        vact_12c
        ch_cir_1 ch_cir_2 ch_cir_3 ch_cir_4 ch_cir_5
        ch_hlth_p
        drnk_12_1 drnk_12_2
        smoke_12
        r11doctim_q2 r11doctim_q3 r11doctim_q4

        ts1_5 ts2_5 ts3_5 ts4_5 ts5_5
      ;

      cluster = hhid ;
      stratification = raestrat;
      weight is r11wtresp;

      tscores =   ts1_5 ts2_5 ts3_5 ts4_5 ts5_5;

      count is r11cesd r12cesd r13cesd r14cesd r15cesd;

      define:
      !calculate time scores
        ts1_5 = (r11agey_b - 74)/2;
        ts2_5 = (r12agey_b - 74)/2;
        ts3_5 = (r13agey_b - 74)/2;
        ts4_5 = (r14agey_b - 74)/2;
        ts5_5 = (r15agey_b - 74)/2;

      !centering all covariates so intercept is at mean 
      center r11agey_b female mar_12 black other latinx nonus_b
              educ_c_1 educ_c_3
              inc_q2_12 inc_q3_12 inc_q4_12
              wlt_q2_12 wlt_q3_12 wlt_q4_12
              bmi_12un bmi_12ow bmi_12ob
              vact_12c
              ch_cir_1 ch_cir_2 ch_cir_3 ch_cir_4 ch_cir_5
              ch_hlth_p
              drnk_12_1 drnk_12_2
              smoke_12
              r11doctim_q2 r11doctim_q3 r11doctim_q4 (grandmean);


   analysis:
      type = complex random;
      estimator = mlr;
      processors = 15;

   model:
      dep_i dep_s|
      r11cesd r12cesd r13cesd r14cesd r15cesd at ts1_5 ts2_5 ts3_5 ts4_5 ts5_5;

     dep_i ON
        art_1_12 hbp_1_12 oth_sin_cond_12
        hbp_art hbp_hrt_art hbp_dia_art hbp_dia_hrt_art
        hbp_can_art hbp_dia hrt_art can_art hbp_lng_art
        oth_comb
        r11agey_b female mar_12 black other latinx nonus_b
        educ_c_1 educ_c_3
        inc_q2_12 inc_q3_12 inc_q4_12
        wlt_q2_12 wlt_q3_12 wlt_q4_12
        bmi_12un bmi_12ow bmi_12ob
        vact_12c
        ch_cir_1 ch_cir_2 ch_cir_3 ch_cir_4 ch_cir_5
        ch_hlth_p
        drnk_12_1 drnk_12_2
        smoke_12
        r11doctim_q2 r11doctim_q3 r11doctim_q4;

      dep_s on
        art_1_12 hbp_1_12 oth_sin_cond_12
        hbp_art hbp_hrt_art hbp_dia_art hbp_dia_hrt_art
        hbp_can_art hbp_dia hrt_art can_art hbp_lng_art
        oth_comb
        r11agey_b female mar_12 black other latinx nonus_b
        educ_c_1 educ_c_3
        inc_q2_12 inc_q3_12 inc_q4_12
        wlt_q2_12 wlt_q3_12 wlt_q4_12
        bmi_12un bmi_12ow bmi_12ob
        vact_12c
        ch_cir_1 ch_cir_2 ch_cir_3 ch_cir_4 ch_cir_5
        ch_hlth_p
        drnk_12_1 drnk_12_2
        smoke_12
        r11doctim_q2 r11doctim_q3 r11doctim_q4;

       !allow covariates to correlate freely for FIML
        art_1_12 hbp_1_12 oth_sin_cond_12
        hbp_art hbp_hrt_art hbp_dia_art hbp_dia_hrt_art
        hbp_can_art hbp_dia hrt_art can_art hbp_lng_art
        oth_comb
        r11agey_b female mar_12 black other latinx nonus_b
        educ_c_1 educ_c_3
        inc_q2_12 inc_q3_12 inc_q4_12
